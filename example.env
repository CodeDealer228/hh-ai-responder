# Ссылка на поиск вакансий
HH_SEARCH_URL=https://hh.ru/search/vacancy?text=python

# ID резюме (если не указан — используется последнее)
HH_RESUME=

# Провайдер ИИ: ollama (по умолчанию, локально и бесплатно) или openrouter
HH_AI_PROVIDER=ollama

# Локальная Ollama. Для Docker вместо localhost нужно указывать IP компьютера в
# локальной сети или host.docker.internal (на Docker Desktop для Windows/Mac).
HH_OLLAMA_BASE_URL=http://localhost:11434
HH_OLLAMA_MODEL=llama3.1:8b
HH_OLLAMA_API_KEY=

# OpenRouter — используется только если HH_AI_PROVIDER=openrouter
HH_OPENROUTER_BASE_URL=https://openrouter.ai/api
HH_OPENROUTER_MODEL=openrouter/free
HH_OPENROUTER_API_KEY=
